# Curated wrapper-oriented subset of upstream Honcho v3.0.3 configuration.
# This is not a full mirror of upstream config.toml.example.
# Use it as a recommended local starting point and consult the upstream tagged release for the broader config surface.

[app]
LOG_LEVEL = "INFO"
NAMESPACE = "honcho"

[db]
CONNECTION_URI = "postgresql+psycopg://postgres:postgres@database:5432/postgres"
SCHEMA = "public"
POOL_PRE_PING = true

[auth]
USE_AUTH=false
# JWT_SECRET = "your-jwt-secret-here"  # required when USE_AUTH = true

[cache]
ENABLED = true
URL = "redis://redis:6379/0?suppress=true"

[llm]
# Default upstream embedding model: text-embedding-3-small
EMBEDDING_PROVIDER = "openai"

[deriver]
ENABLED = true
WORKERS = 1
# Default upstream deriver model: gemini-2.5-flash-lite
PROVIDER = "google"
MODEL = "gemini-2.5-flash-lite"

[summary]
ENABLED = true
# Default upstream summary model: gemini-2.5-flash
PROVIDER = "google"
MODEL = "gemini-2.5-flash"

[dialectic.levels.minimal]
PROVIDER = "google"
MODEL = "gemini-2.5-flash-lite"
THINKING_BUDGET_TOKENS = 0
MAX_TOOL_ITERATIONS = 1
MAX_OUTPUT_TOKENS = 250

[dialectic.levels.low]
PROVIDER = "google"
MODEL = "gemini-2.5-flash-lite"
THINKING_BUDGET_TOKENS = 0
MAX_TOOL_ITERATIONS = 5

[dialectic.levels.medium]
PROVIDER = "anthropic"
MODEL = "claude-haiku-4-5"
THINKING_BUDGET_TOKENS = 1024
MAX_TOOL_ITERATIONS = 2

[dialectic.levels.high]
PROVIDER = "anthropic"
MODEL = "claude-haiku-4-5"
THINKING_BUDGET_TOKENS = 1024
MAX_TOOL_ITERATIONS = 4

[dialectic.levels.max]
PROVIDER = "anthropic"
MODEL = "claude-haiku-4-5"
THINKING_BUDGET_TOKENS = 2048
MAX_TOOL_ITERATIONS = 10

[dream]
ENABLED = true
# Default upstream dream model: claude-sonnet-4-20250514
PROVIDER = "anthropic"
MODEL = "claude-sonnet-4-20250514"
DEDUCTION_MODEL = "claude-haiku-4-5"
INDUCTION_MODEL = "claude-haiku-4-5"

# This example now mirrors the broader upstream v3.0.3 recommendations:
# - OpenAI for embeddings -> text-embedding-3-small
# - Gemini for deriver and summaries -> gemini-2.5-flash-lite and gemini-2.5-flash
# - Anthropic for higher dialectic levels and dreaming -> claude-haiku-4-5 and claude-sonnet-4-20250514

[vector_store]
TYPE = "pgvector"
MIGRATED = false
