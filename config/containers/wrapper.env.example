# Wrapper-control settings for the honcho-container repository itself
# These values are not read from a workspace's honcho-home/.env.
# Set them in the shell environment, your host profile, or another wrapper-specific env source.

# Host base root for named workspaces
HONCHO_BASE_ROOT=~/Documents/Ezirius/.applications-data/Honcho

# Upstream Honcho source
HONCHO_REPO_URL=https://github.com/plastic-labs/honcho.git
# Default wrapper behaviour is latest-release, falling back to the latest upstream tag
# when no GitHub release entry exists.
HONCHO_REF=latest-release

# Local image/project naming
HONCHO_IMAGE_NAME=honcho-local
HONCHO_PROJECT_PREFIX=honcho

# Optional GitHub API base override for latest-release resolution
HONCHO_GITHUB_API_BASE=https://api.github.com
