# Host base root for named workspaces
HONCHO_BASE_ROOT=$HOME/Documents/Ezirius/.applications-data/Honcho

# Honcho upstream source
HONCHO_REPO_URL=https://github.com/plastic-labs/honcho.git
# Use the latest upstream tagged release by default.
# Override this with a specific tag or branch if needed.
HONCHO_REF=latest-release

# Honcho image/project naming
HONCHO_IMAGE_NAME=honcho-local
HONCHO_PROJECT_PREFIX=honcho

# Honcho API host port -> container port 8000
HONCHO_API_HOST_PORT=8000

# Honcho Postgres host port -> container port 5432
# Leave empty to keep Postgres internal only
HONCHO_DB_HOST_PORT=

# Honcho Redis host port -> container port 6379
# Leave empty to keep Redis internal only
HONCHO_REDIS_HOST_PORT=

# Runtime configuration
LOG_LEVEL=INFO
AUTH_USE_AUTH=false
SENTRY_ENABLED=false
METRICS_ENABLED=false

# LLM provider keys
# At least one provider API key is required to start.
# If you mirror upstream Honcho's recommended v3.0.3 config split, you will usually want:
# - OpenAI for embeddings -> text-embedding-3-small
# - Gemini for deriver and summary -> gemini-2.5-flash-lite and gemini-2.5-flash
# - Anthropic for higher-level dialectic and dreaming -> claude-haiku-4-5 and claude-sonnet-4-20250514
# Groq remains supported, but it is optional for this recommended setup.
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_API_KEY=
LLM_GEMINI_API_KEY=
LLM_GROQ_API_KEY=
