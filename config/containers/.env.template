# Workspace runtime settings for one Honcho workspace
# Copy this file to <workspace>/honcho-home/.env and set the values needed for that workspace.
# Wrapper-control settings such as HONCHO_BASE_ROOT, HONCHO_REPO_URL, HONCHO_REF,
# HONCHO_IMAGE_NAME, and HONCHO_PROJECT_PREFIX belong outside the workspace runtime env.
# See config/containers/wrapper.env.example for those wrapper-control examples.

# Honcho API host port -> container port 8000
HONCHO_API_HOST_PORT=8000

# Honcho Postgres host port -> container port 5432
# Leave empty to keep Postgres internal only
HONCHO_DB_HOST_PORT=

# Honcho Redis host port -> container port 6379
# Leave empty to keep Redis internal only
HONCHO_REDIS_HOST_PORT=

# Runtime configuration
LOG_LEVEL=INFO
AUTH_USE_AUTH=false
# AUTH_JWT_SECRET=your-jwt-secret-here  # required when AUTH_USE_AUTH=true
SENTRY_ENABLED=false
METRICS_ENABLED=false

# LLM provider keys
# At least one provider path must be configured for the providers you actually use.
# Recommended upstream v3.0.3-oriented subset:
# - OpenAI for embeddings -> text-embedding-3-small
# - Gemini for deriver and summary -> gemini-2.5-flash-lite and gemini-2.5-flash
# - Anthropic for higher-level dialectic and dreaming -> claude-haiku-4-5 and claude-sonnet-4-20250514
# Additional upstream v3.0.3 provider paths such as OpenAI-compatible, OpenRouter, and vLLM are also supported.
# OpenAI-compatible/OpenRouter paths require both API key and base URL.
# vLLM paths require both API key and base URL.
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_API_KEY=
LLM_GEMINI_API_KEY=
LLM_GROQ_API_KEY=
# LLM_OPENAI_COMPATIBLE_BASE_URL=
# LLM_OPENAI_COMPATIBLE_API_KEY=
# LLM_VLLM_API_KEY=
# LLM_VLLM_BASE_URL=
