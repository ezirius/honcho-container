#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0")

Ensure the shared Honcho image exists.

By default this resolves the latest upstream GitHub release, prints the effective
image build inputs, and builds the shared image only when it does not already
exist."
fi

if [[ $# -ne 0 ]]; then
  usage_error "$(basename "$0") takes no arguments"
fi

require_podman
require_podman_compose

HONCHO_REF="$(resolve_honcho_ref)"
HONCHO_WRAPPER_FINGERPRINT="$(local_build_fingerprint)"
export HONCHO_REF HONCHO_WRAPPER_FINGERPRINT

if image_exists; then
  echo "==> Honcho image already exists: $HONCHO_IMAGE_NAME"
  echo "==> Skipping rebuild"
  exit 0
fi

WORKSPACE_INPUT="(shared image build)"
WORKSPACE_ROOT="(resolved at runtime)"
HONCHO_HOME_DIR="(resolved at runtime)"
HONCHO_WORKSPACE_DIR="(resolved at runtime)"
HONCHO_ENV_FILE="(resolved at runtime)"
HONCHO_CONFIG_TOML="(resolved at runtime)"
DATA_POSTGRES_DIR="(resolved at runtime)"
DATA_REDIS_DIR="(resolved at runtime)"
HONCHO_PROJECT_NAME="${HONCHO_PROJECT_PREFIX}-shared"

COMPOSE_OVERRIDE_FILE="$(mktemp)"
COMPOSE_ENV_FILE="$(mktemp)"
trap 'rm -f "$COMPOSE_ENV_FILE" "$COMPOSE_OVERRIDE_FILE"' EXIT
create_compose_env_file "$COMPOSE_ENV_FILE" /dev/null
create_compose_override "$COMPOSE_OVERRIDE_FILE"

print_summary
echo "==> Local build fingerprint: $HONCHO_WRAPPER_FINGERPRINT"
echo "==> Building Honcho image"
run_compose "$COMPOSE_ENV_FILE" "$COMPOSE_OVERRIDE_FILE" build --pull --no-cache api deriver
echo "==> Honcho image build complete"
