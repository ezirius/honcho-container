#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name> [compose log args...]

Show Honcho logs for one workspace.

By default this shows a snapshot of the current logs. Pass compose log args to
change behaviour.

Common compose log args:
- -f                        follow logs
- --tail 100                show the latest 100 lines
- api                       show only the api service"
fi

if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") requires at least 1 argument: <workspace-name> [compose service args...]"
fi

require_podman
require_podman_compose

resolve_workspace "$1"
require_existing_workspace
migrate_legacy_workspace_layout
if [[ -f "$HONCHO_ENV_FILE" ]]; then
  load_runtime_env_file "$HONCHO_ENV_FILE"
fi
shift

COMPOSE_ENV_FILE="$(mktemp)"
COMPOSE_OVERRIDE_FILE="$(mktemp)"
trap 'rm -f "$COMPOSE_ENV_FILE" "$COMPOSE_OVERRIDE_FILE"' EXIT
create_compose_env_file "$COMPOSE_ENV_FILE" "$HONCHO_ENV_FILE"
create_compose_override "$COMPOSE_OVERRIDE_FILE" "$COMPOSE_ENV_FILE"

echo "==> Honcho logs: $HONCHO_PROJECT_NAME"
run_compose "$COMPOSE_ENV_FILE" "$COMPOSE_OVERRIDE_FILE" logs "$@"
