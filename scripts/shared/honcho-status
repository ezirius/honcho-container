#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name>

Show the current Honcho stack status for one workspace.

This prints the compose service state and, when the API service is already
running, also reports whether the local API health endpoint is reachable."
fi

if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") requires exactly 1 argument: <workspace-name>"
fi

require_podman
require_podman_compose
require_python3

resolve_workspace "$1"
require_existing_workspace
migrate_legacy_workspace_layout
if [[ -f "$HONCHO_ENV_FILE" ]]; then
  load_runtime_env_file "$HONCHO_ENV_FILE"
fi

COMPOSE_ENV_FILE="$(mktemp)"
COMPOSE_OVERRIDE_FILE="$(mktemp)"
trap 'rm -f "$COMPOSE_ENV_FILE" "$COMPOSE_OVERRIDE_FILE"' EXIT
create_compose_env_file "$COMPOSE_ENV_FILE" "$HONCHO_ENV_FILE"
create_compose_override "$COMPOSE_OVERRIDE_FILE" "$COMPOSE_ENV_FILE"

print_summary
echo "==> Services"
STATUS_OUTPUT="$(stack_status_output "$COMPOSE_ENV_FILE" "$COMPOSE_OVERRIDE_FILE")"
printf '%s\n' "$STATUS_OUTPUT"

if stack_has_running_services "$STATUS_OUTPUT"; then
  if python3 - "$(honcho_api_url)/openapi.json" <<'PY'
import http.client
from urllib.request import urlopen
import sys
from urllib.error import HTTPError, URLError

try:
    with urlopen(sys.argv[1], timeout=5) as response:
        raise SystemExit(0 if 200 <= response.status < 300 else 1)
except (URLError, HTTPError, http.client.HTTPException, ConnectionError, OSError):
    raise SystemExit(1)
PY
  then
    echo "==> Honcho API is healthy: $(honcho_api_url)"
  else
    echo "==> Honcho API is not healthy yet: $(honcho_api_url)"
    exit 1
  fi
else
  echo "==> Honcho API is not running"
  exit 1
fi
