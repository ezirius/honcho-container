#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name>

Stop the Honcho stack for one workspace without removing workspace data."
fi

if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") requires exactly 1 argument: <workspace-name>"
fi

require_podman
require_podman_compose

resolve_workspace "$1"
ensure_workspace_dirs
migrate_legacy_workspace_layout
if [[ -f "$HONCHO_ENV_FILE" ]]; then
  load_runtime_env_file "$HONCHO_ENV_FILE"
fi

COMPOSE_ENV_FILE="$(mktemp)"
COMPOSE_OVERRIDE_FILE="$(mktemp)"
trap 'rm -f "$COMPOSE_ENV_FILE" "$COMPOSE_OVERRIDE_FILE"' EXIT
create_compose_env_file "$COMPOSE_ENV_FILE" "$HONCHO_ENV_FILE"
create_compose_override "$COMPOSE_OVERRIDE_FILE"

echo "==> Stopping Honcho stack: $HONCHO_PROJECT_NAME"
run_compose "$COMPOSE_ENV_FILE" "$COMPOSE_OVERRIDE_FILE" stop
echo "==> Honcho stack stopped"
